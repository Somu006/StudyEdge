[Unit]
Description=MachineWhisperer Frontend (serve)
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/AI-Compressor-Predictive-Maintenance/Frontend
ExecStart=/usr/bin/npx serve -s dist -l 3000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mw-frontend

Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
